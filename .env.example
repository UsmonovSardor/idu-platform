# ── Required ────────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway injects this automatically)
DATABASE_URL=postgres://user:password@host:5432/dbname

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# ── Optional (defaults shown) ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# JWT expiry
JWT_EXPIRES_IN=8h

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# CORS — comma-separated additional origins (Railway URL already whitelisted)
CORS_ORIGIN=https://your-custom-domain.com

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Logging level: error | warn | info | http | debug
LOG_LEVEL=info

# AI integrations (optional — AI features disabled if missing)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
